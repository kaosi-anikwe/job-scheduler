# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_scheduler

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Worker ────────────────────────────────────────────────
WORKER_CONCURRENCY=4
SCHEDULER_ENGINE=heap  # heap | timing_wheel

# ── Dead-Letter Queue ─────────────────────────────────────
DLQ_ALERT_THRESHOLD=10
DLQ_ALERT_EMAIL=admin@dilamme.com

# ── SMTP (for DLQ email alerts) ───────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
